{
  "manifest_version": 3,
  "name": "TokenSmith — Ed Discussion Auto‑Answerer",
  "version": "1.0.0",
  "description": "Fetches unanswered Ed Discussion questions and posts answers generated by the local TokenSmith server.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://us.edstem.org/*",
    "https://edstem.org/*",
    "https://au.edstem.org/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
